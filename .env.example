# Honcho backend URL — use Docker service name when on the same network
HONCHO_API_URL=http://honcho-api-1:8000

# API key — passed through to the Honcho SDK, then to Honcho backend.
# Only matters if backend has AUTH_USE_AUTH=true.
# When auth is disabled on the backend, any string (or empty) works.
HONCHO_API_KEY=any-value-works-when-auth-disabled

# Optional
# HONCHO_WORKSPACE_ID=default
# PORT=3000
# HOST=0.0.0.0
